POSTGRES_USER=rewardtodo
POSTGRES_PASSWORD=rewardtodo
POSTGRES_DB=rewardtodo
DATABASE_URL=postgresql://rewardtodo:rewardtodo@db:5432/rewardtodo
READONLY_TOKEN=replace-me
# Preferred bootstrap login credentials.
# Legacy APP_BASIC_AUTH_USER / APP_BASIC_AUTH_PASSWORD are still accepted,
# but new setups should use AUTH_INITIAL_*.
AUTH_INITIAL_USERNAME=reward
AUTH_INITIAL_PASSWORD=replace-me
AUTH_COOKIE_SECURE=false
AUTH_ENABLE_API_TOKENS=true
AUTH_ENABLE_MCP=true
ENABLE_BASIC_AUTH=false
